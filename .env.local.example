# 复制为 .env.local 并填入真实 Key（勿提交到 git）
# 配置后重启：pnpm dev  或  pnpm preview

# 图片 / PDF 扫描页 → 豆包视觉（火山引擎 Ark 平台）
DOUBAO_API_KEY=你的豆包_API_Key
DOUBAO_MODEL_ID=doubao-1-5-vision-pro-32k

# 纯文本 / PDF 文字层 → DeepSeek
DEEPSEEK_API_KEY=你的_DeepSeek_API_Key
DEEPSEEK_MODEL_ID=deepseek-chat

# 音频上传语音转录 → 火山引擎「智能语音技术」
# 获取方式：火山引擎控制台 → 产品 → 智能语音技术 → 应用管理 → 新建应用
# 选择「语音识别」能力，获得 AppID 和 Access Token
VOLC_ASR_APP_ID=你的语音应用_AppID
VOLC_ASR_TOKEN=你的语音应用_AccessToken

# 若你只在 Vite 里配过 VITE_ 前缀，也可写成：
# VITE_DOUBAO_API_KEY=
# VITE_DEEPSEEK_API_KEY=

# 预览/内测访问口令（仅 Vercel Preview 环境配置，Production 留空）
# 配置后访问预览链接需输入口令，学生使用的生产地址不受影响
# VITE_DEMO_ACCESS_CODE=imemo2026test
